<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Sphere{% endblock %}</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
            background-color: #000000;
            color: #ffffff;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #161616;
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #222;
            margin-top: 40px;
            margin-bottom: 40px;
        }
        .header {
            padding: 40px;
            text-align: center;
            background: linear-gradient(180deg, #1a1a1a 0%, #161616 100%);
        }
        .logo {
            margin-bottom: 20px;
        }
        .content {
            padding: 0 40px 40px 40px;
        }
        .footer {
            padding: 30px;
            text-align: center;
            border-top: 1px solid #222;
            background-color: #0a0a0a;
            color: #555;
            font-size: 12px;
        }
        h1 {
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 20px;
        }
        p {
            color: #888;
            line-height: 1.6;
            font-size: 16px;
        }
        .highlight {
            color: #A6FD7A;
        }
        .btn {
            display: inline-block;
            padding: 14px 28px;
            background: linear-gradient(90deg, #A6FD7A 0%, #E7F586 100%);
            color: #000 !important;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">
                <img src="cid:logo" alt="Sphere Logo" width="120">
            </div>
            <h1>{% block header_title %}{% endblock %}</h1>
        </div>
        <div class="content">
            {% block body %}{% endblock %}
        </div>
        <div class="footer">
            <p style="margin: 0; color: #444;">&copy; 2026 Sphere Social Network. Crafted for the elite.</p>
            <p style="margin-top: 8px; color: #333; font-size: 11px;">Ceci est un message automatique, merci de ne pas y répondre.</p>
        </div>
    </div>
</body>
</html>
